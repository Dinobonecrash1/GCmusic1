# --- Telegram Bot API ---
TOKEN=paste_your_bot_token_from_botfather

# --- Telegram MTProto (Pyrogram / PyTgCalls) ---
API_ID=1234567
API_HASH=your_api_hash_from_my_telegram_org

# --- Assistant userbot for music streaming (Pyrogram v2 string session) ---
# Generate this by running the tiny helper below on your machine:
#
#   pip install "pyrogram==2.0.106" "tgcrypto==1.2.5"
#   python -c "from pyrogram import Client; \
#              Client('gen', api_id=API_ID, api_hash='API_HASH').run(lambda: None)"
# then use `Client.export_session_string()` from an interactive shell.
STRING_SESSION=paste_your_pyrogram_v2_string_session_here

# --- Database ---
MONGO_DB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Owner / Support ---
OWNER_ID=123456789
SUPPORT_CHAT=your_support_chat_username
EVENT_LOGS=-1001234567890
START_IMG=https://telegra.ph/file/your-start-image.jpg

# --- Optional: Spotify link resolution ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Optional API keys ---
CASH_API_KEY=
TIME_API_KEY=

# --- Bot flags (leave defaults) ---
ENV=True
ALLOW_EXCL=True
DEL_CMDS=True
STRICT_GBAN=True
WORKERS=8
